# ==============================
# Lab 17 - Multi-Memory Agent
# Environment template
# ==============================

# App
APP_ENV=development
APP_DEBUG=true

# LLM provider: openai | anthropic | gemini
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# LangSmith / tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=lab17-multi-memory-agent

# Runtime settings (can override configs/settings.yaml)
MEMORY_BUDGET=1200
WINDOW_SIZE=8
SEMANTIC_TOP_K=3
USE_REAL_VECTOR_DB=false
PROFILE_MAX_FACTS=10
EPISODIC_MAX_ITEMS=5

# Data paths
PROFILE_STORE_PATH=data/profile/profile.json
EPISODIC_STORE_PATH=data/episodic/episodes.jsonl
SEMANTIC_KB_PATH=data/semantic/knowledge_base.md

# Redis (optional profile backend)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Vector DB / Chroma (optional semantic backend)
CHROMA_PERSIST_DIR=data/semantic/embeddings
CHROMA_COLLECTION=lab17_memory

# Embedding model
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
